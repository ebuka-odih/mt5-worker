# Atlas 5k worker template for a separate Windows/MT5 machine.
# Verified Atlas 5k tunnel at time of writing; replace if a newer tunnel is issued.
VPS_API_BASE=https://pushed-protection-sample-regulations.trycloudflare.com
WORKER_TOKEN=<paste-token-from-vps-config>
WORKER_ID=windows-mt5-atlas-5k-01
DRY_RUN=false
MT5_MAGIC=552701
POLL_SECONDS=1
HEARTBEAT_SECONDS=10
REQUEST_TIMEOUT_MS=5000
