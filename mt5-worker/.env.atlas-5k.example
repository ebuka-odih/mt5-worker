# Atlas 5k worker template for a separate Windows/MT5 machine.
# Paste the currently active Atlas 5k tunnel or direct 8782 URL here.
VPS_API_BASE=https://CHANGE_ME_ATLAS_5K_TUNNEL_OR_HOST
WORKER_TOKEN=<paste-token-from-vps-config>
WORKER_ID=windows-mt5-atlas-5k-01
# Safety guard: set this to the exact MT5 account login shown in the new Atlas 5k terminal.
# The worker refuses live trades if Windows MT5 is logged into a different account.
EXPECTED_MT5_LOGIN=CHANGE_ME_ATLAS_5K_LOGIN
DRY_RUN=false
MT5_MAGIC=552701
POLL_SECONDS=1
HEARTBEAT_SECONDS=10
REQUEST_TIMEOUT_MS=5000
