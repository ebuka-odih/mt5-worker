# Atlas 50k worker template for a separate Windows/MT5 machine.
# This is for the new login account only. Do not overwrite the old worker .env.
VPS_API_BASE=https://CHANGE_ME_ATLAS_50K_TUNNEL_OR_HOST
WORKER_TOKEN=CHANGE_ME_ATLAS_50K_INSTANT_WORKER_TOKEN
WORKER_ID=windows-mt5-atlas-50k-01
DRY_RUN=false
MT5_MAGIC=552650
POLL_SECONDS=1
HEARTBEAT_SECONDS=10
REQUEST_TIMEOUT_MS=5000
