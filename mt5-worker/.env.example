# Windows MT5 Worker Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED: VPS API endpoint (use Cloudflare tunnel URL from VPS)
# =============================================================================
VPS_API_BASE=https://your-cloudflare-tunnel-url.trycloudflare.com

# =============================================================================
# REQUIRED: Shared secret token (must match VPS_WORKER_TOKEN in VPS .env)
# Generate a strong random token, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
WORKER_TOKEN=CHANGE_ME_TO_A_STRONG_RANDOM_TOKEN

# Worker identifier (optional, defaults to windows-mt5-local-01)
WORKER_ID=windows-mt5-local-01

# =============================================================================
# MODE: Set to true for testing, false for live trading
# =============================================================================
DRY_RUN=true

# =============================================================================
# MT5 Configuration (optional)
# =============================================================================
MT5_MAGIC=552501
POLL_SECONDS=1

# =============================================================================
# Retry configuration (optional)
# =============================================================================
MAX_RETRIES=3
RETRY_DELAY=2